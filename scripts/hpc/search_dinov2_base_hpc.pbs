#!/bin/bash
#PBS -l select=1:ncpus=4:mem=32gb:ngpus=1
#PBS -l walltime=08:00:00
#PBS -N dinov2_base_search
#PBS -o logs/dinov2_base_search.out
#PBS -e logs/dinov2_base_search.err

# --- Customise these before submitting ---
PROJECT_DIR="/rds/general/user/zj1024/home/irc-classification-project"
IMAGES_DIR="$PROJECT_DIR/data/raw"

cd "$PROJECT_DIR"

mkdir -p logs

echo "=== DINOv2-Base grid search (12 configs) ==="
echo "Started: $(date)"

uv run python scripts/search.py \
    --models dinov2_base \
    --epochs 100 \
    --head_type mlp \
    --dropout 0.5 \
    --patience 10 \
    --freeze_backbone \
    --output_dir runs/search_dinov2_base \
    --images_dir "$IMAGES_DIR" \
    --python_cmd "uv run python"

echo ""
echo "=== All done: $(date) ==="
